---
import { getCollection } from "astro:content";
import { paginateCollection } from "../../lib/paginate";
import BlogLayout from "@layouts/BlogLayout.astro";
import MyTags from "@components/MyTags.astro";
import BlogPost from "@components/BlogPost.astro";

// Let Astro infer the correct type (IMPORTANT)
const posts = await getCollection("blog");

const page = Number(Astro.params.page ?? 1);

// Pagination (type-safe because we don't widen types manually)
const {
    items: paginatedPosts,
    hasNext,
    hasPrev,
    page: currentPage,
    totalPages,
} = paginateCollection(
    posts,
    page,
    10,
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BlogLayout title="All Posts" subtitle="Archive">
    <div slot="full">
        <h1>All Posts</h1>
        <div class="posts-grid">
            {
                paginatedPosts.map((post) => (
                    <BlogPost
                        url={`/posts/${post.id}/`}
                        title={post.data.title}
                        image={post.data.image}
                    />
                ))
            }
        </div>

        <div class="pagination">
            {hasPrev && <a href={`/posts/${currentPage - 1}`}>← Newer</a>}

            <span>
                Page {currentPage} / {totalPages}
            </span>

            {hasNext && <a href={`/posts/${currentPage + 1}`}>Older →</a>}
        </div>
    </div>

    <div slot="tags">
        <h1>All Post Tags</h1>
        <MyTags />
    </div>
</BlogLayout>
