---
import BlogPost from "../../components/BlogPost.astro";
import BlogLayout from "../../layouts/BlogLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type BlogPostEntry = CollectionEntry<"blog">;

export async function getStaticPaths(): Promise<Array<{ params: { tag: string }; props: { posts: BlogPostEntry[] } }>> {
    const allPosts = await getCollection("blog");
    const uniqueTags = [
        ...new Set(allPosts.flatMap((post) => post.data.tags ?? [])),
    ];

    return uniqueTags.map((tag) => {
        const filteredPosts = allPosts.filter((post) =>
            post.data.tags?.includes(tag),
        );
        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}

const { tag } = Astro.params as { tag?: string };
const currentTag = tag ?? "";
const { posts } = Astro.props as { posts: BlogPostEntry[] };
---

<BlogLayout pageTitle={tag}>
    <div slot="main-text">
        <p>Posts tagged with {tag}</p>
        <ul>
            {
                posts.map((post) => (
                    <BlogPost
                        url={`/posts/${post.id}/`}
                        title={post.data.title}
                        image={post.data.image}
                    />
                ))
            }
        </ul>
    </div>
</BlogLayout>
