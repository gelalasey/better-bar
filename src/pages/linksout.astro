---
import Layout from "../layouts/Layout.astro";

import "../styles/webring.css";

const title = "shuttle";
const subtitle = "links out";
const bannerImage = "/bg/ondatrain.gif";
const tinyImage = "/smalls/sm-trolley.gif";
---

<Layout
    title={title}
    subtitle={subtitle}
    bannerImage={bannerImage}
    tinyImage={tinyImage}
>
    <div slot="main-text">
        <div class="splitscreen">
            <div class="splitcell">
                <img
                    src="/link-backs/gelseybanner-tiny.png"
                    alt="ticket to gelseyland"
                />
            </div>
            <div class="splitcell">
                <h3>link back?</h3>
                <div class="codebox">
                    <code
                        >&lt;a
                        href=&quot;https://gelseyland.neocities.org/&quot;
                        target=&quot;_blank&quot;&gt;&lt;img
                        src=&quot;yourcodehere.png&quot; alt=&quot;ticket to
                        gelseyland&quot;&gt;&lt;/a&gt;</code
                    >
                </div>
            </div>
        </div>
        <img src="/div/bluepinkdiv.png" />
        <p>
            don't stop surfing! click on one of my favorite sites to continue
            your journey around the web! web neighbors are mutuals and open for
            request. If you'd like to link to me please save the image to your
            own files and copy the code. <mark>
                remember: don't link to my page for the image url.
            </mark> this is called
            <a href="https://mailchimp.com/resources/hotlinking/">
                hot linking</a
            > and is considered rude in online ettiquette!
        </p>
    </div>

    <div slot="full">
        <h2>favorite sites</h2>
        <a href="https://eunoia.sayitditto.net/" target="_blank"
            ><img src="/link-backs/eunoiabutton.png" /></a
        >
        <a href="https://www.lejlart.com/apple.html" target="_blank"
            ><img
                src="/link-backs/AD_meltycorn.gif"
                alt="Eunoia say it ditto"
            /></a
        >
        <a href="https://cinni.net/" target="_blank"
            ><img src="/link-backs/cinni_angelbutton3.gif" /></a
        >
        <a href="https://cepheus.neocities.org/stars/" target="_blank"
            ><img
                alt="click to visit cepheus"
                src="/link-backs/button2.gif"
            /></a
        >
        <a href="https://maya.land/" target="_blank"
            ><img src="/link-backs/mayalandbanner.png" /></a
        >
        <a href="https://luvstarkei.com/about/" target="_blank"
            ><img src="/link-backs/LuvstarKeiButton-1.webp" /></a
        >
        <a href="https://lilithdev.neocities.org/"
            ><img
                src="https://lilithdev.neocities.org/buttons/lilithdevbtn.gif"
            /></a
        >
        <a target="_blank" href="https://kwaamfan.neocities.org/"
            ><img src="https://files.catbox.moe/egpfu7.gif" alt="kwaamfan" /></a
        >
        <a target="_blank" href="https://lostletters.neocities.org/"
            ><img src="/link-backs/LostLetters88x31.gif" alt="lostletters" /></a
        >
        <a target="_blank" href="https://doqmeat.com/"
            ><img src="/link-backs/doqmeat-2.png" alt="doqmeat" /></a
        >
        <a href="http://sweetcharm.net/" target="_blank"
            ><img
                src="/link-backs/bannericeream.gif"
                width="88"
                height="31"
            /></a
        >

        <a href="https://decodreams.neocities.org/" target="_blank"
            ><img
                src="https://decodreams.neocities.org/buttons/decodreamsbutton1.gif"
                alt='decodreams"'
            /></a
        >
        <a href="https://xandra.cc/" target="_blank"
            ><img src="https://xandra.cc/88x31-by-rosedryad.png" /></a
        >
        <a href="https://softheartclinic.neocities.org/home" target="_blank"
            ><img src="/link-backs/softheartclinic.gif" /></a
        >
        <a href="https://faeraphim.net/main/index.htm" target="_blank"
            ><img src="/link-backs/faelink.png" /></a
        >
        <a href="www.thefrugalgamer.net/" target="_blank"
            ><img src="/link-backs/frugalgamer_button1.png" /></a
        >
        <a href="https://jackisnotbright.neocities.org/" target="_blank"
            ><img src="/link-backs/NEWLINKBACK.gif" /></a
        >
        <a href="https://mustardgrass.neocities.org/"
            ><img
                src="https://mustardgrass.neocities.org/Button1.gif"
                width="88px"
                height="31px"
            /></a
        >
        <a href="http://pixeldolls.net/" target="_blank">
            <img src="https://i.postimg.cc/4yB9zVPG/banner.gif" /></a
        >
        <a href="https://peachlantern.neocities.org/" target="_blank">
            <img src="/link-backs/peachlanternlinks.gif" /></a
        >
    </div>

    <div slot="left-half">
        <h2>web neighbors</h2>
        <a target="_blank" href="http://lockheart.love/collections/cliques"
            ><img
                src="https://file.garden/ZrZSgsrYfQXsO7QH/buttons/lockheartlinksbtn.png"
            /></a
        >
        <a
            href="https://yuuya.thoughtcube.org/sub-blog/stuff.html"
            target="_blank"><img src="/link-backs/yuuya88x31.png" /></a
        >
        <p>
            <b>Want to be web neighbors?</b> email me @ gelseyland(at)proton(dot)me
        </p>
        <div>
            <img src="/images/balloongirlleft.gif" />
            <img src="/images/ballholders.gif" />
            <img src="/images/balloongirlright.gif" />
        </div>
    </div>
    <div slot="right-half">
        <h2>Cliques</h2>
        <ul>
            <li>
                <a href="https://lockheart.love/collections/cliques"
                    >Cringe is Dead</a
                > || Doll Collecting and Role Playing Chats
            </li>
            <li>
                <a href="https://lockheart.love/collections/cliques"
                    >Language Learning
                </a>
                <img src="/clique/ll-orange.png" /> Javascript, SLO, JPN
            </li>
            <li>
                <link
                    rel="stylesheet"
                    href="https://reef.kingdra.net/kpop.css"
                />
                <p class="kpop-clique">
                    <span class="kpop-text">k-pop</span>
                    <a href="https://reef.kingdra.net">♥ ♫</a>
                    <span class="kpop-group">XLOV</span>
                </p>
            </li>
            <li>
                <a href="https://garden.cainhurst.org">girly gamer</a>
                <img src="/clique/whitepurple.png" /> [PC/Mobile]
            </li>
        </ul>
        <div>
            <img src="/clique/pompompurin.png" />
            <a href="https://nanacore.net/cliques/sanrio">sanrio</a> ♡
            <img src="/clique/txt-pompompurin.png" />
        </div>
        <a
            href="http://sailorcrystal.net/guardians/"
            target="_blank"
            title="protected by Senshi Venus"
            ><img
                src="/clique/venus.png"
                class="prettyguardians"
                alt="senshi venus"
            /></a
        >
        <a href="LINK"
            ><img
                src="https://file.garden/ZkEY3dxjtja0xEri/tfc/tr-protect.png"
            /></a
        >
    </div>
</Layout>
